generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model debt_history {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  debt_id    String?  @db.Uuid
  date       DateTime @db.Date
  type_label String   @db.VarChar(20)
  person     String   @db.VarChar(100)
  action     String   @db.VarChar(50)
  status     String   @default("Pending") @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  debts      debts?   @relation(fields: [debt_id], references: [id], onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, date(sort: Desc)], map: "idx_debt_history_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model debts {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String         @db.Uuid
  type         String         @db.VarChar(12)
  person       String         @db.VarChar(100)
  amount       Decimal        @db.Decimal(12, 2)
  due_date     DateTime?      @db.Date
  status       String         @default("Pending") @db.VarChar(20)
  base_status  String         @default("Pending") @db.VarChar(20)
  notes        String         @default("") @db.VarChar(200)
  paid_at      DateTime?      @db.Date
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  debt_history debt_history[]
  users        users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_debts_user_id")
  @@index([user_id, type], map: "idx_debts_user_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model records {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  description String   @db.VarChar(100)
  amount      Decimal  @db.Decimal(12, 2)
  category    String   @db.VarChar(50)
  date        DateTime @db.Date
  currency    String   @default("RWF") @db.VarChar(3)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, date(sort: Desc)], map: "idx_records_user_date")
  @@index([user_id], map: "idx_records_user_id")
}

model refresh_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @db.VarChar(255)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_refresh_tokens_hash")
  @@index([user_id], map: "idx_refresh_tokens_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model schedule {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  title         String    @db.VarChar(100)
  type          String    @default("work") @db.VarChar(10)
  due_date      DateTime  @db.Date
  reminder_date DateTime? @db.Date
  priority      String    @default("Medium") @db.VarChar(10)
  status        String    @default("Pending") @db.VarChar(20)
  amount        Decimal   @default(0) @db.Decimal(12, 2)
  notes         String    @default("") @db.VarChar(200)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, due_date], map: "idx_schedule_user_due")
  @@index([user_id], map: "idx_schedule_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model settings {
  user_id               String   @id @db.Uuid
  usd_rate              Decimal  @default(1300) @db.Decimal(10, 2)
  eur_rate              Decimal  @default(1450) @db.Decimal(10, 2)
  cap                   Decimal  @default(0) @db.Decimal(12, 2)
  theme                 String   @default("light") @db.VarChar(10)
  default_currency      String   @default("RWF") @db.VarChar(3)
  display_currency      String   @default("RWF") @db.VarChar(3)
  show_weekly_chart     Boolean  @default(true)
  compact_table         Boolean  @default(false)
  confirm_before_delete Boolean  @default(true)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @default(now()) @db.Timestamptz(6)
  users                 users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String           @unique @db.VarChar(255)
  password_hash  String           @db.VarChar(255)
  display_name   String           @default("Student") @db.VarChar(100)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  debt_history   debt_history[]
  debts          debts[]
  records        records[]
  refresh_tokens refresh_tokens[]
  schedule       schedule[]
  settings       settings?

  @@index([email], map: "idx_users_email")
}
