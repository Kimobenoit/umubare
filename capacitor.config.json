{
  "appId": "com.studentbudgettracker.app",
  "appName": "Budget Tracker",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#3b82f6",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#3b82f6"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "scheme": "BudgetTracker"
  }
}
